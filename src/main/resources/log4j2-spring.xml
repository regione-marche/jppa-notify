<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss} [%t] %-5p %c - %m%n</Property>
    </Properties>
    <Appenders>
        <Console name="STDOUT" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>
        <RollingFile name="jppa-notify"
                	  fileName="C:/work/git/jppa-notify/log/jppa-notify.log"
                	  filePattern="%d{yyyy-MM-dd}-jppa-notify.%i.log.gz"
                	  ignoreExceptions="false" filePermissions="rw-rw-r--">
            <PatternLayout pattern="${LOG_PATTERN}"/>
			<!-- <JsonTemplateLayout eventTemplateUri="classpath:ElasticsearchJsonEventLayoutV1.json"/> -->
            <Policies>
                <SizeBasedTriggeringPolicy size="60MB" />
            </Policies>
            <!-- <DefaultRolloverStrategy max="10" /> -->
            <ThresholdFilter level="INFO"/>
        </RollingFile>
        <RollingFile name="jppa-notify-error"
                	 fileName="C:/work/git/jppa-notify/log/jppa-notify-error.log"
                	 filePattern="jppa-notify-error.%i.log"
                     ignoreExceptions="false" filePermissions="rw-rw-r--">
			<JsonTemplateLayout eventTemplateUri="classpath:ElasticsearchJsonEventLayoutV1.json"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="60MB" />
            </Policies>
            <ThresholdFilter level="ERROR"/>
        </RollingFile>
    </Appenders>
    <Loggers>
		<Logger name="it.maggioli.pagopa.pagonet.jppanotify" level="DEBUG" additivity="false">
			<AppenderRef ref="jppa-notify" />
            <!-- <AppenderRef ref="com-seda-cart-ws-debug" /> -->
            <AppenderRef ref="jppa-notify-error" />
		</Logger>         
        <Root level="INFO" >
            <AppenderRef ref="STDOUT" />
        </Root>
    </Loggers>
</Configuration>
